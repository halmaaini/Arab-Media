# الموسوعة الذكية — environment variables (docs/11.1)
# Copy to .env.local for dev. NEVER commit real values.

# --- Client (embedded in the public bundle; safe ONLY because RLS is enabled) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Contact-form widget (public Turnstile site key)
VITE_TURNSTILE_SITE_KEY=
# Error tracking (optional)
VITE_SENTRY_DSN=

# --- Server / seed / CI ONLY — must NOT be VITE_-prefixed, never in the bundle ---
# Used by scripts/seed.mjs and scripts/extract-seed snapshot loading.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Server-side verification for the contact form (submit-message function)
TURNSTILE_SECRET_KEY=
